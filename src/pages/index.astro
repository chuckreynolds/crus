---
import { Picture } from 'astro:assets';
import headshot from '../assets/chuck-bmw-square.jpg';
import '../styles/global.css';

const title = 'Chuck Reynolds - AI Training Data & Enterprise API Platforms';
const description = 'Chuck Reynolds - Staff PM at Wikimedia Enterprise, the API platform behind Wikipedia data. AI training corpora, retrieval and grounding, developer experience.';
const socialDescription = 'Chuck Reynolds - Staff Product Manager at Wikimedia Enterprise. I ship the API platform that AI labs and search engines use for training data, retrieval, and grounding. AI product strategy, enterprise APIs, technical SEO.';
const canonical = 'https://chuckreynolds.com';
const image = `${canonical}/chuck-reynolds-social-card.jpg`;
const imageAlt = 'Chuck Reynolds: AI product strategy, enterprise APIs, and AI training data';

const siteId = `${canonical}/#website`;
const pageId = `${canonical}/#webpage`;
const personId = `${canonical}/#chuck`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': siteId,
      url: canonical,
      name: 'Chuck Reynolds',
      description,
      publisher: { '@id': personId },
      copyrightHolder: { '@id': personId },
      copyrightYear: new Date().getFullYear(),
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': pageId,
      url: canonical,
      name: title,
      description,
      isPartOf: { '@id': siteId },
      about: { '@id': personId },
      primaryImageOfPage: image,
      inLanguage: 'en-US',
    },
    {
      '@type': 'Person',
      '@id': personId,
      name: 'Chuck Reynolds',
      jobTitle: 'Staff Product Manager, Growth at Wikimedia Enterprise',
      url: canonical,
      email: 'mailto:hello@chuckreynolds.com',
      image,
      description:
        'Staff Product Manager, Growth at Wikimedia Enterprise, the commercial API platform for Wikipedia and Wikidata. Builds the training corpora, retrieval APIs, and developer tooling that AI labs and search engines use to ground models in open knowledge.',
      knowsAbout: [
        'AI training data',
        'Retrieval-augmented generation',
        'LLM grounding and attribution',
        'AI product strategy',
        'Enterprise API product management',
        'Developer experience',
        'Structured data extraction',
        'ML data pipelines',
        'Wikipedia and Wikidata',
        'Knowledge graphs',
        'Technical SEO',
        'Web performance',
      ],
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Arizona State University',
      },
      worksFor: {
        '@type': 'Organization',
        name: 'Wikimedia Foundation',
        url: 'https://enterprise.wikimedia.com',
      },
      sameAs: [
        'https://x.com/chuckreynolds',
        'https://www.linkedin.com/in/chuckreynolds',
        'https://github.com/chuckreynolds',
        'https://bsky.app/profile/chuckreynolds.com',
        'https://www.youtube.com/chuckreynolds',
        'https://mastodon.xyz/@chuck',
        'https://www.instagram.com/chuckreynolds/',
      ],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1a202c" />

    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="Chuck Reynolds" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="en_US" />
    <meta property="profile:first_name" content="Chuck" />
    <meta property="profile:last_name" content="Reynolds" />
    <meta property="profile:username" content="chuckreynolds" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chuckreynolds" />
    <meta name="twitter:creator" content="@chuckreynolds" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'dark' || stored === 'light') {
            document.documentElement.setAttribute('data-theme', stored);
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <button
      type="button"
      role="switch"
      class="theme-toggle"
      data-theme-toggle
      aria-checked="false"
      aria-label="Switch theme"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" aria-hidden="true">
        <path d="M223.5 32C100 32 0 132.3 0 256S100 480 223.5 480c60.6 0 115.5-24.2 155.8-63.4c5-4.9 6.3-12.5 3.1-18.7s-10.1-9.7-17-8.5c-9.8 1.7-19.8 2.6-30.1 2.6c-96.9 0-175.5-78.8-175.5-176c0-65.8 36-123.1 89.3-153.3c6.1-3.5 9.2-10.5 7.7-17.3s-7.3-11.9-14.3-12.5c-6.3-.5-12.6-.8-19-.8z"/>
      </svg>
